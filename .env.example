# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_32chars
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production

# AI — Ollama is default (free). Set ANTHROPIC_API_KEY only if using Claude
ANTHROPIC_API_KEY=

# OAuth (free)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage — minio for dev, r2 for production
STORAGE_PROVIDER=minio
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Email (Gmail SMTP or Brevo free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
